{
	"compilerOptions": {
		"target": "ES2020",
		"useDefineForClassFields": true,
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"jsx": "react-jsx",

		"strict": true,
		"skipLibCheck": true,

		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"],
			"@lumio/shared": ["packages/shared/src/index.ts"],
			"@lumio/shared/*": ["packages/shared/src/*"]
		},

		"types": ["vite/client", "vite-plugin-pwa/client", "node", "react", "react-dom"],

		"allowSyntheticDefaultImports": true
	},
	"include": ["src", "vite.config.ts"]
}
